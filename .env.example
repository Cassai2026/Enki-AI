OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Default provider: openai | anthropic
ENKI_PROVIDER=openai

# Model names
ENKI_OPENAI_MODEL=gpt-4o
ENKI_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Max tokens for completion
ENKI_MAX_TOKENS=4096

# Max conversation turns kept in memory (0 = unlimited)
ENKI_MEMORY_WINDOW=20

# API server
ENKI_API_HOST=0.0.0.0
ENKI_API_PORT=8000
