# Enki-AI Configuration Template
# Copy this file to .env and fill in your actual keys

# --- API Keys ---
GEMINI_API_KEY=your_google_gemini_api_key_here

# --- Database & Storage ---
# Path to your SQLite database or project storage
PROJECTS_PATH=./projects
DATABASE_URL=sqlite:///./enki_db.sqlite

# --- Security ---
# Secret key for session management or token signing
SECRET_KEY=generate_a_random_string_here

# --- Optional Features ---
# Set to 'True' if you want to enable experimental features
ENABLE_GAME_ENGINE=False
