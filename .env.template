ENKI_API_KEY=your_google_genai_api_key_here
# Google GenAI API key — get one at https://aistudio.google.com/app/apikey
# Used by ada.py / gemini_bridge.py for all LLM calls.

JURISDICTION_URL=https://hollis.harvard.edu
# URL of the external knowledge/legal scraper target.
# Default points at Harvard Hollis for governance/legal research.

SOVEREIGN_ID=ROOT_29
# Unique identifier for this Enki node.
# NODE 29 is the founding Sovereign node. Change only if running a child node.

# ── API / Database ────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
# Host address the Flask REST API binds to. Use 0.0.0.0 to allow LAN access.

API_PORT=5000
# Port the Flask REST API listens on.

DB_PATH=data/form_submissions.db
# Path (relative to project root) where the SQLite form-submissions DB lives.

# ── Memory Store ──────────────────────────────────────────────────────────────
MEMORY_DB_PATH=data/enki_memory.db
# Path for the SQLite conversation-memory database used by enki_ai.core.memory_store.
# Stores recent conversation turns so Enki can recall prior context.

MEMORY_MAX_TURNS=200
# Maximum number of conversation turns to keep per session in the memory store.

# ── TTS (Piper) ───────────────────────────────────────────────────────────────
PIPER_DIR=~/Downloads/piper_windows_amd64/piper
# Absolute path to your Piper TTS installation directory.
# Download from: https://github.com/rhasspy/piper/releases

PIPER_VOICE=en_GB-vctk-medium
# Piper voice model name (without .onnx extension).
# Voice files must exist at $PIPER_DIR/voices/<PIPER_VOICE>.onnx

# ── Wake Word ─────────────────────────────────────────────────────────────────
WAKE_WORD=jarvis
# The word Enki listens for to activate. Case-insensitive.

# ── HUD ───────────────────────────────────────────────────────────────────────
HUD_PORT=7777
# Port the Sovereign HUD WebSocket server listens on.

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Python logging level. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.

# ── Gemini LLM (SovereignBrain) ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Google Gemini API key used by enki_ai.core.sovereign_brain (SovereignBrain).
# The google-genai SDK also reads this variable automatically.
# Get a key at: https://aistudio.google.com/app/apikey

GEMINI_MODEL=gemini-2.0-flash-exp
# Gemini model to use for LLM queries.
# Other options: gemini-1.5-flash, gemini-1.5-pro